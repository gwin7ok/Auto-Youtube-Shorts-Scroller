content.js:560 [Auto Youtube Shorts Scroller] {filters: Array(9)}
(function setSlider(percent){
  const el = document.querySelector('input#volume-input') || document.querySelector('.ytp-volume-slider');
  if (!el) return console.log('no slider element found');
  if (el.tagName === 'INPUT') {
    el.value = String(percent);
    el.dispatchEvent(new Event('input', {bubbles:true}));
    el.dispatchEvent(new Event('change', {bubbles:true}));
  } else {
    el.setAttribute('aria-valuenow', String(percent));
    el.dispatchEvent(new Event('input', {bubbles:true}));
    el.dispatchEvent(new Event('change', {bubbles:true}));
  }
  console.log('fired slider events to', el);
})(70);
