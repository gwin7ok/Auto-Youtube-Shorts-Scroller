{
  "manifest_version": 3,
  "name": "Auto Youtube Shorts Scroller",
  "version": "3.1.3",
  "description": "Automatically scrolls to the next Youtube Short when one ends!",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "icons": {
    "16": "img/autoYTScrollerIcon16.png",
    "48": "img/autoYTScrollerIcon48.png",
    "128": "img/autoYTScrollerIcon128.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject-page.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "img/autoYTScrollerIcon16.png",
      "48": "img/autoYTScrollerIcon48.png",
      "128": "img/autoYTScrollerIcon128.png"
    },
    "default_title": "Auto YouTube Shorts Scroller"
  }
}